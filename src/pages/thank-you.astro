---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Thank You — We'll Be in Touch | OpsHQ Digital"
  description="Your message has been received. We'll review your project and reach out within 24 hours."
>
  <section class="py-24 md:py-32">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="text-6xl mb-6">✅</div>
      <h1 class="text-3xl md:text-4xl font-bold text-navy-950 mb-4">
        Thank You — We're On It
      </h1>
      <p class="text-lg text-slate-600 mb-8 max-w-xl mx-auto">
        Your message has been received. We'll review your project and reach out within 24 hours with a clear next step. No sales pitch — just an honest conversation about what's possible.
      </p>

      <div class="bg-slate-50 rounded-xl p-8 mb-12 max-w-lg mx-auto text-left">
        <h2 class="text-lg font-bold text-navy-950 mb-4">What Happens Next</h2>
        <ol class="space-y-4">
          <li class="flex gap-3">
            <span class="flex-shrink-0 w-7 h-7 bg-blue-500 text-white rounded-full flex items-center justify-center text-sm font-bold">1</span>
            <div>
              <strong class="text-navy-950">We review your project</strong>
              <p class="text-sm text-slate-500 mt-0.5">Usually within a few hours during business days</p>
            </div>
          </li>
          <li class="flex gap-3">
            <span class="flex-shrink-0 w-7 h-7 bg-blue-500 text-white rounded-full flex items-center justify-center text-sm font-bold">2</span>
            <div>
              <strong class="text-navy-950">We reach out to schedule a call</strong>
              <p class="text-sm text-slate-500 mt-0.5">Free 30-minute discovery call at your convenience</p>
            </div>
          </li>
          <li class="flex gap-3">
            <span class="flex-shrink-0 w-7 h-7 bg-blue-500 text-white rounded-full flex items-center justify-center text-sm font-bold">3</span>
            <div>
              <strong class="text-navy-950">You get a clear proposal</strong>
              <p class="text-sm text-slate-500 mt-0.5">Fixed pricing, defined scope, no surprises</p>
            </div>
          </li>
        </ol>
      </div>

      <h2 class="text-xl font-bold text-navy-950 mb-6">While You Wait — See What We've Built</h2>
      
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 max-w-2xl mx-auto">
        <a href="/work/transportation-crm/" class="block bg-white border border-slate-200 rounded-xl p-6 hover:shadow-lg hover:border-blue-300 transition-all text-left">
          <div class="text-2xl mb-3">🚐</div>
          <h3 class="font-bold text-navy-950 mb-2">Transportation CRM</h3>
          <p class="text-sm text-slate-600">How we turned email chaos into a 200+ lead pipeline with AI agents</p>
          <span class="text-blue-500 text-sm font-medium mt-3 inline-block">Read the case study →</span>
        </a>
        
        <a href="/work/content-platform/" class="block bg-white border border-slate-200 rounded-xl p-6 hover:shadow-lg hover:border-blue-300 transition-all text-left">
          <div class="text-2xl mb-3">📝</div>
          <h3 class="font-bold text-navy-950 mb-2">Content Platform</h3>
          <p class="text-sm text-slate-600">Automated daily publishing with page-one Google rankings</p>
          <span class="text-blue-500 text-sm font-medium mt-3 inline-block">Read the case study →</span>
        </a>
      </div>

      <div class="mt-12 pt-8 border-t border-slate-200">
        <p class="text-sm text-slate-500">
          Questions in the meantime? Email <a href="mailto:nick@opshqdigital.com" class="text-blue-500 hover:underline">nick@opshqdigital.com</a> anytime.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
