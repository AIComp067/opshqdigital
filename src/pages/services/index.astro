---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ServiceCard from '../../components/ServiceCard.astro';
---
<BaseLayout
  title="AI-Powered Automation for Small Business | OpsHQ Digital"
  description="AI automation, CRM systems, websites & cloud infrastructure built for small businesses looking to scale or modernize."
>
  <!-- Hero -->
  <section class="relative overflow-hidden text-white">
    <img src="/images/hero-services.jpg" alt="" class="absolute inset-0 w-full h-full object-cover opacity-20" />
    <div class="absolute inset-0 bg-gradient-to-b from-navy-950/90 to-navy-900/95"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center py-16 md:py-24">
      <h1 class="text-4xl md:text-5xl font-bold mb-6">Technology That Solves Real Business Problems</h1>
      <p class="text-lg text-slate-300 max-w-2xl mx-auto">You shouldn't have to become a tech expert to run your business. Here's how we take technology off your plate — so you can focus on what you do best.</p>
    </div>
  </section>

  <!-- Services Grid -->
  <section class="py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
        <!-- CRM -->
        <div class="bg-white rounded-xl border border-slate-200 p-8 hover:shadow-lg hover:border-blue-300 transition-all">
          <div class="text-3xl mb-4">🖥️</div>
          <h3 class="text-xl font-bold text-navy-950 mb-3">CRM & Business Automation</h3>
          <p class="text-slate-600 leading-relaxed mb-4">Custom CRM systems that track every lead, automate follow-ups, and tell you exactly what needs attention today.</p>
          <ul class="space-y-2 text-sm text-slate-600 mb-4">
            <li>✓ Custom lead tracking that matches YOUR sales process</li>
            <li>✓ Automated daily digest — know your whole business in one email</li>
            <li>✓ Payment tracking and automated invoicing</li>
            <li>✓ AI-powered email drafts in your brand voice</li>
            <li>✓ Real-time sync with your existing tools</li>
          </ul>
          <p class="text-sm text-teal-500 font-medium mb-4">Starting at $5,000</p>
          <a href="/services/crm/" class="text-sm font-medium text-blue-500 hover:text-blue-600 transition-colors">Learn More About CRM →</a>
        </div>

        <!-- AI -->
        <div class="bg-white rounded-xl border border-slate-200 p-8 hover:shadow-lg hover:border-blue-300 transition-all">
          <div class="text-3xl mb-4">🤖</div>
          <h3 class="text-xl font-bold text-navy-950 mb-3">AI Agents & Intelligent Automation</h3>
          <p class="text-slate-600 leading-relaxed mb-4">AI agents that read emails, draft responses in your voice, route leads, and handle the boring stuff.</p>
          <ul class="space-y-2 text-sm text-slate-600 mb-4">
            <li>✓ AI email agents that sound like your best employee</li>
            <li>✓ Smart lead routing — the right inquiry goes to the right workflow</li>
            <li>✓ Save 15+ hours/week on manual processes</li>
            <li>✓ Content automation and scheduling</li>
            <li>✓ Intelligent monitoring with proactive alerts</li>
          </ul>
          <p class="text-sm text-teal-500 font-medium mb-4">Starting at $3,000</p>
          <a href="/services/ai/" class="text-sm font-medium text-blue-500 hover:text-blue-600 transition-colors">Learn More About AI Automation →</a>
        </div>

        <!-- Web -->
        <div class="bg-white rounded-xl border border-slate-200 p-8 hover:shadow-lg hover:border-blue-300 transition-all">
          <div class="text-3xl mb-4">🌐</div>
          <h3 class="text-xl font-bold text-navy-950 mb-3">Web Development</h3>
          <p class="text-slate-600 leading-relaxed mb-4">Fast, search-optimized sites that show up on Google and convert visitors into leads — at a fraction of what you're paying now.</p>
          <ul class="space-y-2 text-sm text-slate-600 mb-4">
            <li>✓ Blazing-fast sites that rank on Google</li>
            <li>✓ Built-in lead capture and conversion tracking</li>
            <li>✓ Minimal hosting costs — no $100+/month hosting bills</li>
            <li>✓ SEO-first architecture — built to rank</li>
            <li>✓ Analytics and conversion tracking from day one</li>
          </ul>
          <p class="text-sm text-teal-500 font-medium mb-4">Starting at $2,500</p>
          <a href="/services/web/" class="text-sm font-medium text-blue-500 hover:text-blue-600 transition-colors">Learn More About Web Development →</a>
        </div>

        <!-- Cloud -->
        <div class="bg-white rounded-xl border border-slate-200 p-8 hover:shadow-lg hover:border-blue-300 transition-all">
          <div class="text-3xl mb-4">☁️</div>
          <h3 class="text-xl font-bold text-navy-950 mb-3">Cloud Infrastructure & DevOps</h3>
          <p class="text-slate-600 leading-relaxed mb-4">Right-sized infrastructure with proper monitoring, automatic deployments, and security.</p>
          <ul class="space-y-2 text-sm text-slate-600 mb-4">
            <li>✓ Right-sized cloud resources — pay for what you actually use</li>
            <li>✓ Automated deployments — no more manual uploads</li>
            <li>✓ 24/7 monitoring with proactive alerts</li>
            <li>✓ Security hardening and compliance</li>
            <li>✓ DNS, CDN, and performance optimization</li>
          </ul>
          <p class="text-sm text-teal-500 font-medium mb-4">Starting at $2,000</p>
          <a href="/services/cloud/" class="text-sm font-medium text-blue-500 hover:text-blue-600 transition-colors">Learn More About Cloud →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="bg-gradient-to-br from-navy-950 to-navy-800 text-white py-16 md:py-24">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">Not Sure Which Service You Need?</h2>
      <p class="text-lg text-slate-300 mb-8">That's completely normal. Most of our clients start with a conversation, not a shopping list.</p>
      <a href="/contact/" class="inline-flex items-center justify-center px-8 py-4 bg-blue-500 text-white font-medium rounded-lg hover:bg-blue-600 transition-colors min-h-[44px] text-lg">
        Request a Free Discovery Call
      </a>
    </div>
  </section>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "BreadcrumbList",
          "itemListElement": [
            { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://opshqdigital.com/" },
            { "@type": "ListItem", "position": 2, "name": "Services", "item": "https://opshqdigital.com/services/" }
          ]
        },
        {
          "@type": "ProfessionalService",
          "name": "OpsHQ Digital",
          "url": "https://opshqdigital.com/services/",
          "description": "AI automation, CRM systems, websites & cloud infrastructure built for small businesses looking to scale or modernize.",
          "provider": { "@id": "https://opshqdigital.com/#organization" },
          "areaServed": { "@type": "City", "name": "Seattle", "addressRegion": "WA" },
          "hasOfferCatalog": {
            "@type": "OfferCatalog",
            "name": "Technology Services",
            "itemListElement": [
              { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "CRM & Business Automation", "url": "https://opshqdigital.com/services/crm/" } },
              { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "AI Agents & Intelligent Automation", "url": "https://opshqdigital.com/services/ai/" } },
              { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Web Development", "url": "https://opshqdigital.com/services/web/" } },
              { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Cloud Infrastructure & DevOps", "url": "https://opshqdigital.com/services/cloud/" } }
            ]
          }
        }
      ]
    })} />
  </Fragment>
</BaseLayout>
