---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Page Not Found | OpsHQ Digital"
  description="The page you're looking for doesn't exist. Here are some helpful links to get you back on track."
  noindex={true}
>
  <section class="py-24 md:py-32">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-6xl font-bold text-blue-500 mb-4">404</p>
      <h1 class="text-3xl md:text-4xl font-bold text-navy-950 mb-4">This page doesn't exist — but we do.</h1>
      <p class="text-lg text-slate-600 mb-8">The page you're looking for doesn't exist or has moved. Let's get you back on track.</p>
      <div class="flex flex-col sm:flex-row justify-center gap-4">
        <a href="/" class="inline-flex items-center justify-center px-6 py-3 bg-blue-500 text-white font-medium rounded-lg hover:bg-blue-600 transition-colors min-h-[44px]">
          Go to Homepage
        </a>
        <a href="/services/" class="inline-flex items-center justify-center px-6 py-3 border-2 border-slate-300 text-slate-700 font-medium rounded-lg hover:bg-slate-50 transition-colors min-h-[44px]">
          View Our Services
        </a>
        <a href="/contact/" class="inline-flex items-center justify-center px-6 py-3 border-2 border-slate-300 text-slate-700 font-medium rounded-lg hover:bg-slate-50 transition-colors min-h-[44px]">
          Contact Us
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
