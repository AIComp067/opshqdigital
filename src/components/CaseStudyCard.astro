---
interface Props {
  title: string;
  subtitle: string;
  metrics: { value: string; label: string }[];
  href: string;
  badge?: string;
}
const { title, subtitle, metrics, href, badge } = Astro.props;
---
<a href={href} class="group block bg-white rounded-xl border border-slate-200 overflow-hidden hover:shadow-lg hover:border-blue-300 transition-all">
  <div class="bg-gradient-to-br from-navy-950 to-navy-800 h-48 flex items-center justify-center">
    <div class="text-5xl opacity-30">📊</div>
  </div>
  <div class="p-6">
    {badge && (
      <span class="text-xs font-semibold text-teal-500 bg-teal-500/10 px-2.5 py-1 rounded-full">
        {badge}
      </span>
    )}
    <h3 class="text-xl font-bold text-navy-950 mt-3 mb-2 group-hover:text-blue-500 transition-colors">{title}</h3>
    <p class="text-sm text-slate-600 leading-relaxed mb-4">{subtitle}</p>
    <div class="flex flex-wrap gap-3 mb-4">
      {metrics.map(m => (
        <span class="text-xs font-medium bg-slate-100 text-slate-700 px-3 py-1.5 rounded-full">
          <span class="font-bold text-blue-500">{m.value}</span> {m.label}
        </span>
      ))}
    </div>
    <span class="text-sm font-medium text-blue-500 group-hover:text-blue-600 transition-colors">
      Read the full story →
    </span>
  </div>
</a>
